{
  "name": "lightnode (Codespaces / dev container)",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "postCreateCommand": "npm install --no-audit --no-fund",
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "remoteUser": "node",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": { "label": "Inference server / Next.js dev" }
  },
  "containerEnv": {
    "DEV_NOTE": "This Codespace is for working ON the lightnode repo itself (webapp, sdk, scaffolder). To just TRY the SDK with a runnable starter, use the marinom2/lightnode-examples Codespace instead."
  }
}
