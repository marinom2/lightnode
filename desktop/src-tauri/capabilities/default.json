{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core APIs + IPC access for the hosted LightNode UI so detect_hardware and run_command_streamed work in the built app.",
  "windows": ["main"],
  "remote": {
    "urls": ["https://lightnode.app", "http://localhost:3000"]
  },
  "permissions": [
    "core:default",
    "allow-detect-hardware",
    "allow-run-command-streamed",
    "allow-secret-set",
    "allow-secret-get",
    "allow-secret-delete",
    "allow-generate-worker-key"
  ]
}
